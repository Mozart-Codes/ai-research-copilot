{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start:docker": "docker-compose -f docker-compose-dev.yml up -d",
    "stop:docker": "docker-compose -f docker-compose-dev.yml down",
    "clean": "rimraf dist",
    "build": "nest build",
    "start:dev": "nest start --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:ci": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:ci": "eslint \"{src,apps,libs,test}/**/*.ts\" --max-warnings=0",
    "test": "jest --watch",
    "test:ci": "CI=true ENVIRONMENT=test jest --watchAll=false --silent=false --coverage --detectOpenHandles --passWithNoTests",
    "typeorm-cli": "typeorm-ts-node-commonjs",
    "migration:create": "typeorm migration:create src/modules/database/domain/migrations/%npm_config_name%",
    "migration:run": "npm run build && npm run typeorm-cli -- migration:run -d dist/modules/database/infra/DatabaseConfig.js",
    "migration:revert": "npm run build && npm run typeorm-cli -- migration:revert -d dist/modules/database/infra/DatabaseConfig.js"
  },
  "dependencies": {
    "@langchain/textsplitters": "^1.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "@types/multer": "^2.1.0",
    "@types/pdf-parse": "^1.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "joi": "^18.0.2",
    "multer": "^2.1.1",
    "openai": "^6.32.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pgvector": "^0.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
